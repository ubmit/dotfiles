export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="robbyrussell"

plugins=(
	fast-syntax-highlighting
  fzf
	git
	zsh-autosuggestions
	zsh-bat
	zsh-eza
	zsh-syntax-highlighting
)

alias vim=nvim
alias v=nvim
alias lg=lazygit
alias pn=pnpm
alias pnx="pnpm dlx"
alias z=zed
alias opc=opencode
alias cwebp=webp
alias cc="claude --allow-dangerously-skip-permissions"
alias claudio="claude --allow-dangerously-skip-permissions"
alias yolo="claude --allow-dangerously-skip-permissions"
alias gmn="gemini --yolo"
alias cx="codex --dangerously-bypass-approvals-and-sandbox"

# export EDITOR="zed --wait"
export EDITOR="nvim"

source $ZSH/oh-my-zsh.sh

eval "$(fnm env --use-on-cd --shell zsh)"

# Only initialize zoxide in interactive shells to avoid errors in non-interactive contexts (e.g., Claude Code)
if [[ -o interactive ]]; then
  eval "$(zoxide init --cmd cd zsh)"
fi

# starship prompt
eval "$(starship init zsh)"

# pnpm
export PNPM_HOME="/Users/gui/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end

# bun completions
[ -s "/Users/gui/.bun/_bun" ] && source "/Users/gui/.bun/_bun"

export PATH="/opt/homebrew/opt/ruby@3.2/bin:$PATH"

